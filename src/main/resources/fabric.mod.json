{
	"schemaVersion": 1,
	"id": "amagari_translation_tool",
	"version": "${version}",
	"name": "Amagari Translation Tool",
	"description": "A Fabric translation helper mod for Amagari projects.",
	"icon": "assets/amagari_translation_tool/icon.png",
	"authors": [
		"zero-zuiter_ZTXL"
	],
	"contact": {
		"sources": "https://github.com/zuiter/amagari-translation-tool"
	},
	"license": "Apache-2.0",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.amagari.translationtool.AmagariTranslationTool"
		],
		"client": [
			"com.amagari.translationtool.client.AmagariTranslationToolClient"
		]
	},
	"mixins": [
		"amagari_translation_tool.client.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "${minecraft_dependency}",
		"java": ">=25",
		"fabric-api": "*"
	}
}
